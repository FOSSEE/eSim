.title kicad schematic

.include SN74S536.sub
* u4 clk net-_u4-pad2_ adc_bridge_1
x1 net-_u1-pad2_ net-_u5-pad1_ net-_u2-pad2_ net-_u3-pad2_ net-_u5-pad2_ net-_u5-pad3_ net-_u2-pad2_ net-_u3-pad2_ net-_u5-pad4_ unconnected-_x1-pad10_ net-_u4-pad2_ net-_u5-pad5_ net-_u2-pad2_ net-_u3-pad2_ net-_u5-pad6_ net-_u5-pad7_ net-_u2-pad2_ net-_u3-pad2_ net-_u5-pad8_ unconnected-_x1-pad20_ SN74S536
v3 clk gnd pulse(0 5 0 0 0 5m 10m)
v1 en gnd pwl(0 0 19m 0 20m 5 30m 5)
