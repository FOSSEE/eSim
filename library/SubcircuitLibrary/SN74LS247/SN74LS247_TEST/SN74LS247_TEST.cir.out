.title kicad schematic

.include SN74LS247.sub
v1 a gnd pulse(0 5 0 0 0 5m 10m)
v2 b gnd pulse(0 5 0 0 0 10m 20m)
v6 rbi gnd pwl(0 5 79m 5 80m 0 100m 0 )
v5 lamp_test gnd pwl(0 5 89m 5 90m 0 100m 0)
v4 d gnd pulse(0 5 0 0 0 40m 80m)
v3 c gnd pulse(0 5 0 0 0 20m 40m)
* u2 a b c d net-_u2-pad5_ net-_u2-pad6_ net-_u2-pad7_ net-_u2-pad8_ adc_bridge_4
x1 net-_u2-pad6_ net-_u2-pad7_ net-_u3-pad3_ net-_u4-pad2_ net-_u3-pad4_ net-_u2-pad8_ net-_u2-pad5_ unconnected-_x1-pad8_ net-_x1-pad9_ net-_x1-pad10_ net-_x1-pad11_ net-_x1-pad12_ net-_x1-pad13_ net-_x1-pad14_ net-_x1-pad15_ unconnected-_x1-pad16_ SN74LS247
v7 net-_u4-pad1_ gnd 5
* u3 lamp_test rbi net-_u3-pad3_ net-_u3-pad4_ adc_bridge_2
* u4 net-_u4-pad1_ net-_u4-pad2_ adc_bridge_1
* u6 net-_x1-pad14_ net-_u6-pad2_ d_inverter
* u5 net-_x1-pad15_ net-_u5-pad2_ d_inverter
* u1 net-_u5-pad2_ net-_u6-pad2_ net-_u1-pad3_ net-_u1-pad4_ net-_u1-pad5_ net-_u1-pad6_ net-_u1-pad7_ fout gout aout bout cout dout eout dac_bridge_7
* u10 net-_x1-pad10_ net-_u1-pad6_ d_inverter
* u11 net-_x1-pad9_ net-_u1-pad7_ d_inverter
* u8 net-_x1-pad12_ net-_u1-pad4_ d_inverter
* u9 net-_x1-pad11_ net-_u1-pad5_ d_inverter
* u7 net-_x1-pad13_ net-_u1-pad3_ d_inverter
a1 [a b c d ] [net-_u2-pad5_ net-_u2-pad6_ net-_u2-pad7_ net-_u2-pad8_ ] u2
a2 [lamp_test rbi ] [net-_u3-pad3_ net-_u3-pad4_ ] u3
a3 [net-_u4-pad1_ ] [net-_u4-pad2_ ] u4
a4 net-_x1-pad14_ net-_u6-pad2_ u6
a5 net-_x1-pad15_ net-_u5-pad2_ u5
a6 [net-_u5-pad2_ net-_u6-pad2_ net-_u1-pad3_ net-_u1-pad4_ net-_u1-pad5_ net-_u1-pad6_ net-_u1-pad7_ ] [fout gout aout bout cout dout eout ] u1
a7 net-_x1-pad10_ net-_u1-pad6_ u10
a8 net-_x1-pad9_ net-_u1-pad7_ u11
a9 net-_x1-pad12_ net-_u1-pad4_ u8
a10 net-_x1-pad11_ net-_u1-pad5_ u9
a11 net-_x1-pad13_ net-_u1-pad3_ u7
* Schematic Name:                             adc_bridge_4, Ngspice Name: adc_bridge
.model u2 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
