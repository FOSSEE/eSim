.title kicad schematic

.include LM321.sub
.include INVCMOS.sub
.include LM393.sub
.include ZenerD1N750.lib
x4 net-_x1-pad2_ net-_x2-pad2_ net-_r3-pad1_ net-_x4-pad4_ gnd LM321
v4 v8 gnd 6
* u3 net-_u1-pad3_ net-_u1-pad4_ net-_u2-pad1_ d_or
* u2 net-_u2-pad1_ c dac_bridge_1
x7 i_b b INVCMOS
x8 i_a a INVCMOS
x9 c d INVCMOS
* u1 i_a i_b net-_u1-pad3_ net-_u1-pad4_ adc_bridge_2
r3 net-_r3-pad1_ net-_r3-pad2_ 1k
v2 net-_r3-pad1_ gnd 7
d1 gnd net-_r3-pad2_ D1N750
v6 v7 gnd 3
x1 v8 net-_x1-pad2_ net-_r3-pad1_ net-_x1-pad2_ gnd LM321
x3 net-_x1-pad2_ net-_x2-pad2_ net-_r3-pad1_ net-_x3-pad4_ gnd LM321
x2 v9 net-_x2-pad2_ net-_r3-pad1_ net-_x2-pad2_ gnd LM321
v3 v9 gnd 1
x5 net-_r3-pad1_ v7 net-_x3-pad4_ i_a gnd net-_x4-pad4_ v6 i_b LM393
v5 v6 gnd 5
r2 vref vstab 20k
x6 net-_r3-pad2_ vref net-_r3-pad1_ vstab gnd LM321
r1 gnd vref 20k
a1 [net-_u1-pad3_ net-_u1-pad4_ ] net-_u2-pad1_ u3
a2 [net-_u2-pad1_ ] [c ] u2
a3 [i_a i_b ] [net-_u1-pad3_ net-_u1-pad4_ ] u1
* Schematic Name:                             d_or, Ngspice Name: d_or
.model u3 d_or(rise_delay=1.0e-9 fall_delay=1.0e-9 input_load=1.0e-12 ) 
* Schematic Name:                             dac_bridge_1, Ngspice Name: dac_bridge
.model u2 dac_bridge(out_low=0.0 out_high=5.0 out_undef=0.5 input_load=1.0e-12 t_rise=1.0e-9 t_fall=1.0e-9 ) 
* Schematic Name:                             adc_bridge_2, Ngspice Name: adc_bridge
.model u1 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
.tran 10e-09 1e-06 0e-00

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
.endc
.end
