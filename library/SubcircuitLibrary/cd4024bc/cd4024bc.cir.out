.tran 100e-06 10e-03 0e-00

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
plot v(q4)
plot v(q7)
plot v(q5)
plot v(q6)
plot v(q1)
plot v(q2)
plot v(q3)
plot v(clk)
.endc
.end
