.title kicad schematic

.include CD4024BC_ic.sub
* u7 net-_u7-pad1_ q5 dac_bridge_1
* u8 net-_u8-pad1_ q6 dac_bridge_1
* u9 net-_u9-pad1_ q7 dac_bridge_1
* u6 net-_u6-pad1_ q4 dac_bridge_1
* u5 net-_u5-pad1_ q3 dac_bridge_1
* u4 net-_u4-pad1_ q2 dac_bridge_1
* u3 net-_u3-pad1_ q1 dac_bridge_1
r3 gnd q5 1k
r4 gnd q4 1k
r1 gnd q7 1k
r2 gnd q6 1k
x1 net-_u2-pad3_ net-_u2-pad4_ net-_u9-pad1_ net-_u8-pad1_ net-_u7-pad1_ net-_u6-pad1_ unconnected-_x1-pad7_ unconnected-_x1-pad8_ net-_u5-pad1_ unconnected-_x1-pad10_ net-_u4-pad1_ net-_u3-pad1_ unconnected-_x1-pad13_ unconnected-_x1-pad14_ CD4024BC_ic
* u13 q4 plot_v1
* u10 q7 plot_v1
* u12 q5 plot_v1
* u11 q6 plot_v1
* u16 q1 plot_v1
* u15 q2 plot_v1
r5 gnd q3 1k
* u14 q3 plot_v1
r6 gnd q2 1k
r7 gnd q1 1k
* u2 clk net-_u2-pad2_ net-_u2-pad3_ net-_u2-pad4_ adc_bridge_2
v2 clk gnd pulse(0 5 0 1n 1n 500u 1m)
* u1 clk plot_v1
v1 net-_u2-pad2_ gnd 0
a1 [net-_u7-pad1_ ] [q5 ] u7
a2 [net-_u8-pad1_ ] [q6 ] u8
a3 [net-_u9-pad1_ ] [q7 ] u9
a4 [net-_u6-pad1_ ] [q4 ] u6
a5 [net-_u5-pad1_ ] [q3 ] u5
a6 [net-_u4-pad1_ ] [q2 ] u4
a7 [net-_u3-pad1_ ] [q1 ] u3
a8 [clk net-_u2-pad2_ ] [net-_u2-pad3_ net-_u2-pad4_ ] u2
