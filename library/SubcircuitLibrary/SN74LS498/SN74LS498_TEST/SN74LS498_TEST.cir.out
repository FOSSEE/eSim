.title kicad schematic

.include SN74LS498.sub
x1 net-_u1-pad2_ net-_u2-pad3_ net-_u3-pad9_ net-_u3-pad10_ net-_u3-pad11_ net-_u3-pad12_ net-_u3-pad13_ net-_u3-pad14_ net-_u3-pad15_ net-_u3-pad16_ net-_u2-pad4_ net-_u5-pad2_ net-_u6-pad2_ net-_u4-pad8_ net-_u4-pad7_ net-_u4-pad6_ net-_u4-pad5_ net-_u4-pad4_ net-_u4-pad3_ net-_u4-pad2_ net-_u4-pad1_ net-_u6-pad1_ SN74LS498
* u2 i0 i1 net-_u2-pad3_ net-_u2-pad4_ adc_bridge_2
* u3 gnd net-_u3-pad2_ net-_u3-pad2_ net-_u3-pad2_ net-_u3-pad2_ net-_u3-pad2_ gnd net-_u3-pad2_ net-_u3-pad9_ net-_u3-pad10_ net-_u3-pad11_ net-_u3-pad12_ net-_u3-pad13_ net-_u3-pad14_ net-_u3-pad15_ net-_u3-pad16_ adc_bridge_8
v2 i0 gnd pwl(0 5 19 5 20 0 39 0 40 5 59 5 60 0 100 0)
* u1 clk net-_u1-pad2_ adc_bridge_1
v1 net-_u3-pad2_ gnd 5
v4 clk gnd pulse(0 5 0 0 0 5 10)
v3 i1 gnd pwl(0 5 39 5 40 0 100 0)
* u6 net-_u6-pad1_ net-_u6-pad2_ liro rilo dac_bridge_2
* u4 net-_u4-pad1_ net-_u4-pad2_ net-_u4-pad3_ net-_u4-pad4_ net-_u4-pad5_ net-_u4-pad6_ net-_u4-pad7_ net-_u4-pad8_ q0 q1 q2 q3 q4 q5 q6 q7 dac_bridge_8
* u5 oc_b net-_u5-pad2_ adc_bridge_1
v5 oc_b gnd pwl(0 0 79 0 80 5 100 5)
a1 [i0 i1 ] [net-_u2-pad3_ net-_u2-pad4_ ] u2
a2 [gnd net-_u3-pad2_ net-_u3-pad2_ net-_u3-pad2_ net-_u3-pad2_ net-_u3-pad2_ gnd net-_u3-pad2_ ] [net-_u3-pad9_ net-_u3-pad10_ net-_u3-pad11_ net-_u3-pad12_ net-_u3-pad13_ net-_u3-pad14_ net-_u3-pad15_ net-_u3-pad16_ ] u3
a3 [clk ] [net-_u1-pad2_ ] u1
a4 [net-_u6-pad1_ net-_u6-pad2_ ] [liro rilo ] u6
a5 [net-_u4-pad1_ net-_u4-pad2_ net-_u4-pad3_ net-_u4-pad4_ net-_u4-pad5_ net-_u4-pad6_ net-_u4-pad7_ net-_u4-pad8_ ] [q0 q1 q2 q3 q4 q5 q6 q7 ] u4
a6 [oc_b ] [net-_u5-pad2_ ] u5
