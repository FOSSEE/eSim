* Control Statements 
.control
run
let clk_s = v(CLK)
let i1_s = v(I1) + 6.0
let i0_s = v(I0) + 12.0
let liro_s = v(LIRO) + 18.0
let rilo_s = v(RILO) + 24.0
let q0_s = v(Q0) + 30.0
let q1_s = v(Q1) + 36.0
let q2_s = v(Q2) + 42.0
let q3_s = v(Q3) + 48.0
let q4_s = v(Q4) + 54.0
let q5_s = v(Q5) + 60.0
let q6_s = v(Q6) + 66.0
let q7_s = v(Q7) + 72.0
plot q0_s q1_s q2_s q3_s q4_s q5_s q6_s q7_s
.endc
.end
