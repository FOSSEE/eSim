a1 [net-_u8-pad1_ net-_u8-pad2_ net-_u8-pad3_ net-_u8-pad4_ net-_u8-pad5_ net-_u8-pad6_ net-_u8-pad7_ net-_u8-pad8_ ] [q0 q1 q2 q3 q4 q5 q6 q7 ] u8
