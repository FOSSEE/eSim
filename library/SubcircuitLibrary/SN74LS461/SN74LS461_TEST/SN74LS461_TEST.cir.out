* Control Statements 
.control
run
let clk_s = v(CLK)
let i1_s = v(I1) + 6.0
let i0_s = v(I0) + 12.0
let ci_s = v(CI_B) + 18.0
let oc_s = v(OC_B) + 24.0
let q0_s = v(Q0) + 30.0
let q1_s = v(Q1) + 36.0
let q2_s = v(Q2) + 42.0
let q3_s = v(Q3) + 48.0
