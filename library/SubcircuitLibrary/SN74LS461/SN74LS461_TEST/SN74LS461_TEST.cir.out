* u9 net-_u9-pad1_ carry_out dac_bridge_1
x1 net-_u4-pad2_ net-_u6-pad3_ net-_u5-pad9_ net-_u5-pad10_ net-_u5-pad11_ net-_u5-pad12_ net-_u5-pad13_ net-_u5-pad14_ net-_u5-pad15_ net-_u5-pad16_ net-_u6-pad4_ net-_u10-pad4_ net-_u9-pad1_ net-_u8-pad8_ net-_u8-pad7_ net-_u8-pad6_ net-_u8-pad5_ net-_u8-pad4_ net-_u8-pad3_ net-_u8-pad2_ net-_u8-pad1_ net-_u10-pad3_ SN74LS461
