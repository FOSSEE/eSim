.title kicad schematic

.include 74ls173_ic.sub
* u8 g net-_u8-pad2_ adc_bridge_1
x1 net-_u5-pad2_ net-_u5-pad2_ net-_u10-pad1_ unconnected-_x1-pad4_ unconnected-_x1-pad5_ unconnected-_x1-pad6_ net-_u6-pad2_ unconnected-_x1-pad8_ net-_u8-pad2_ net-_u8-pad2_ net-_u4-pad2_ net-_u4-pad2_ net-_u4-pad2_ net-_u4-pad2_ net-_u9-pad2_ unconnected-_x1-pad16_ 74ls173_ic
* u7 g plot_v1
v4 g gnd pulse(5 0 0 1n 1n 5m 10m)
* u1 mn plot_v1
* u6 clk net-_u6-pad2_ adc_bridge_1
v3 clk gnd pulse(0 5 0 1n 1n 1.5m 3m)
v2 mn gnd pulse(0 5 0 1n 1n 5m 10m)
* u5 mn net-_u5-pad2_ adc_bridge_1
* u4 d net-_u4-pad2_ adc_bridge_1
v1 d gnd pulse(0 5 0 1n 1n 1m 2m)
* u3 d plot_v1
* u2 clk plot_v1
* u11 q plot_v1
* u9 net-_u9-pad1_ net-_u9-pad2_ adc_bridge_1
* u10 net-_u10-pad1_ q dac_bridge_1
v5 net-_u9-pad1_ gnd 0
r1 q gnd 1k
a1 [g ] [net-_u8-pad2_ ] u8
a2 [clk ] [net-_u6-pad2_ ] u6
a3 [mn ] [net-_u5-pad2_ ] u5
a4 [d ] [net-_u4-pad2_ ] u4
a5 [net-_u9-pad1_ ] [net-_u9-pad2_ ] u9
a6 [net-_u10-pad1_ ] [q ] u10
* Schematic Name:                             adc_bridge_1, Ngspice Name: adc_bridge
.model u8 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
* Schematic Name:                             adc_bridge_1, Ngspice Name: adc_bridge
.model u6 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
* Schematic Name:                             adc_bridge_1, Ngspice Name: adc_bridge
.model u5 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
* Schematic Name:                             adc_bridge_1, Ngspice Name: adc_bridge
.model u4 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
* Schematic Name:                             adc_bridge_1, Ngspice Name: adc_bridge
.model u9 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
* Schematic Name:                             dac_bridge_1, Ngspice Name: dac_bridge
.model u10 dac_bridge(out_low=0.0 out_high=5.0 out_undef=0.5 input_load=1.0e-12 t_rise=1.0e-9 t_fall=1.0e-9 ) 
.tran 1e-06 100e-03 0e-00

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
plot v(g)
plot v(mn)
plot v(d)
plot v(clk)
plot v(q)
.endc
.end
