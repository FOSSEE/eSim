.title kicad schematic

.include PNP.lib
.include NPN.lib
* u1 gnd out1 out2 vdd input1 ena input2 gnd unconnected-_u1-pad9_ input3 enb input4 out3 out4 gnd port
q2 out1 net-_u13-pad2_ gnd Q2N2222
q5 out2 net-_u17-pad2_ vdd Q2N2907A
q1 out1 net-_u12-pad2_ vdd Q2N2907A
q6 out2 net-_u16-pad2_ gnd Q2N2222
* u14 net-_u10-pad3_ net-_u14-pad2_ dac_bridge_1
* u10 net-_u10-pad1_ net-_u10-pad2_ net-_u10-pad3_ d_nand
q7 out4 net-_u19-pad2_ vdd Q2N2907A
q3 out3 net-_u14-pad2_ vdd Q2N2907A
* u27 input4 net-_u22-pad1_ adc_bridge_1
* u25 net-_u22-pad1_ net-_u23-pad1_ d_inverter
