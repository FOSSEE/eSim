.title kicad schematic

.include SN74LS353.sub
* u4 net-_u4-pad1_ net-_u4-pad2_ 2y 1y dac_bridge_2
x1 net-_u1-pad3_ net-_u2-pad3_ net-_u3-pad9_ net-_u3-pad10_ net-_u3-pad11_ net-_u3-pad12_ net-_u4-pad2_ unconnected-_x1-pad8_ net-_u4-pad1_ net-_u3-pad16_ net-_u3-pad15_ net-_u3-pad14_ net-_u3-pad13_ net-_u2-pad4_ net-_u1-pad4_ unconnected-_x1-pad16_ SN74LS353
* u3 c3 c2 c1 c0 c3 c2 c1 c0 net-_u3-pad9_ net-_u3-pad10_ net-_u3-pad11_ net-_u3-pad12_ net-_u3-pad13_ net-_u3-pad14_ net-_u3-pad15_ net-_u3-pad16_ adc_bridge_8
v2 b gnd pulse(0 5 0 0 0 10m 20m)
v3 a gnd pulse(0 5 0 0 0 5m 10m)
* u2 b a net-_u2-pad3_ net-_u2-pad4_ adc_bridge_2
* u1 g g net-_u1-pad3_ net-_u1-pad4_ adc_bridge_2
v1 g gnd pwl(0 0 16m 0 17m 5 30m 5)
v4 c3 gnd pulse(0 5 0 0 0 2.5m 5m)
v5 c2 gnd pulse(0 5 0 0 0 2.5m 5m)
v6 c1 gnd pulse(0 5 0 0 0 2.5m 5m)
v7 c0 gnd pulse(0 5 0 0 0 2.5m 5m)
a1 [net-_u4-pad1_ net-_u4-pad2_ ] [2y 1y ] u4
a2 [c3 c2 c1 c0 c3 c2 c1 c0 ] [net-_u3-pad9_ net-_u3-pad10_ net-_u3-pad11_ net-_u3-pad12_ net-_u3-pad13_ net-_u3-pad14_ net-_u3-pad15_ net-_u3-pad16_ ] u3
a3 [b a ] [net-_u2-pad3_ net-_u2-pad4_ ] u2
a4 [g g ] [net-_u1-pad3_ net-_u1-pad4_ ] u1
* Schematic Name:                             dac_bridge_2, Ngspice Name: dac_bridge
.model u4 dac_bridge(out_low=0.0 out_high=5.0 out_undef=0.5 input_load=1.0e-12 t_rise=1.0e-9 t_fall=1.0e-9 ) 
* Schematic Name:                             adc_bridge_8, Ngspice Name: adc_bridge
.model u3 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
* Schematic Name:                             adc_bridge_2, Ngspice Name: adc_bridge
.model u2 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
* Schematic Name:                             adc_bridge_2, Ngspice Name: adc_bridge
.model u1 adc_bridge(in_low=1.0 in_high=2.0 rise_delay=1.0e-9 fall_delay=1.0e-9 ) 
.tran 10e-06 30e-03 0e-03

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
.endc
.end
