.title kicad schematic

.include CA3022.sub
v2 net-_x1-pad5_ gnd  dc 12
v1 inp gnd sine(0 0.4 50 0 0)
* u1 inp plot_v1
c1 net-_c1-pad1_ inp 0.1u
r2 net-_r2-pad1_ net-_r2-pad2_ 3k
x1 net-_c1-pad1_ gnd net-_r2-pad1_ gnd net-_x1-pad5_ gnd net-_r2-pad2_ net-_x1-pad8_ gnd gnd gnd gnd CA3022
r1 gnd net-_x1-pad8_ 1k
.tran 1e-03 75e-03 0e-00

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
plot v(inp)
.endc
.end
