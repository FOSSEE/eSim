.tran 1e-09 250e-09 0e-00

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
set xbrushwidth=2
plot v(done)+6 v(start)+12  v(rst)+18  v(clk)+24
plot v(b0)+6v(b1)+12v(b2)+18v(b3)+24v(b4)+30v(b5)+36v(b6)+42v(b7)+48
plot v(a0)+6v(a1)+12v(a2)+18v(a3)+24v(a4)+30v(a5)+36v(a6)+42v(a7)+48
plot v(g0)+6v(g1)+12v(g2)+18v(g3)+24v(g4)+30v(g5)+36v(g6)+42v(g7)+48
.endc
.end
