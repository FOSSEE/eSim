.title kicad schematic

.include CA3036.sub
v2 net-_x1-pad1_ gnd  dc 9
x1 net-_x1-pad1_ out unconnected-_x1-pad3_ net-_c1-pad1_ net-_x1-pad1_ net-_x1-pad1_ net-_x1-pad1_ unconnected-_x1-pad8_ unconnected-_x1-pad9_ unconnected-_x1-pad10_ CA3036
v1 inp gnd sine(0 2 50 0 0)
* u1 out plot_db
r1 gnd out 1k
* u2 inp plot_db
c1 net-_c1-pad1_ inp 1u
.tran 1e-03 75e-03 0e-00

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
plot db(out)
plot db(inp)
.endc
.end
