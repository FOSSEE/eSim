.title kicad schematic

.include CA3028A.sub
c3 net-_c3-pad1_ gnd 0.01u
r3 gnd net-_c4-pad1_ 2k
v3 net-_r4-pad2_ gnd  dc 9
r4 net-_c4-pad1_ net-_r4-pad2_ 1k
r2 net-_c2-pad1_ net-_c3-pad1_ 50
v2 net-_c2-pad1_ gnd  dc 9
c4 net-_c4-pad1_ gnd 0.01u
c1 inp net-_c1-pad2_ 0.01u
r1 net-_c4-pad1_ net-_c1-pad2_ 50
v1 inp gnd sine(0 3 50 0 0)
c2 net-_c2-pad1_ gnd 0.01u
x1 net-_c1-pad2_ gnd gnd gnd net-_c4-pad1_ net-_c3-pad1_ net-_c2-pad1_ net-_c2-pad1_ CA3028A
.tran 1e-03 50e-03 0e-00

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
.endc
.end
