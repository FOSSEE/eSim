.title kicad schematic

.include CA3054.sub
r2 net-_c1-pad1_ out1 1k
x1 unconnected-_x1-pad1_ unconnected-_x1-pad2_ unconnected-_x1-pad3_ unconnected-_x1-pad4_ unconnected-_x1-pad5_ net-_r1-pad2_ out1 out2 net-_c2-pad1_ unconnected-_x1-pad10_ vx net-_r4-pad1_ unconnected-_x1-pad13_ unconnected-_x1-pad14_ CA3054
* u2 out1 plot_v1
r1 gnd net-_r1-pad2_ 1k
c1 net-_c1-pad1_ gnd 0.1u
v1 net-_c1-pad1_ gnd  dc 12
r4 net-_r4-pad1_ net-_c3-pad1_ 0.5k
* u3 out2 plot_v1
v2 net-_r3-pad1_ gnd  dc 12
r3 net-_r3-pad1_ out2 1k
* u1 vx plot_v1
r6 vx gnd 1k
r5 gnd net-_c2-pad1_ 1k
c2 net-_c2-pad1_ inp 10u
c3 net-_c3-pad1_ gnd 0.1u
* u4 inp plot_v1
v4 net-_c3-pad1_ gnd  dc -6
v3 inp gnd sine(0 0.04 50 0 0)
.tran 1e-03 75e-03 0e-00

* Control Statements 
.control
run
print allv > plot_data_v.txt
print alli > plot_data_i.txt
plot v(out1)
plot v(out2)
plot v(vx)
plot v(inp)
.endc
.end
